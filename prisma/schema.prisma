datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                Int      @id @default(autoincrement())
  username          String   @unique
  passwordHash      String
  adultworkUserId   Int?     @unique
  adultworkNickname String?
  role              String   @default("USER") // "ADMIN", "USER"
  discreetMode      Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model CachedProfile {
  userId                      Int       @id // AdultWork UserID
  nickname                    String
  summary                     String?
  gender                      String?
  age                         Int?
  orientation                 String?
  country                     String?
  region                      String?
  county                      String?
  town                        String?
  nationality                 String?
  nationalityISO2             String?
  views                       Int?
  memberSince                 DateTime?
  lastLoggedIn                DateTime?
  verified                    Boolean   @default(false)
  isEscort                    Boolean   @default(false)
  doesOutCalls                Boolean   @default(false)
  doesInCalls                 Boolean   @default(false)
  isWebcam                    Boolean   @default(false)
  isPhoneChat                 Boolean   @default(false)
  isSMSChat                   Boolean   @default(false)
  isAlternative               Boolean   @default(false)
  isOtherServices             Boolean   @default(false)
  isDirectCam                 Boolean   @default(false)
  isDirectChat                Boolean   @default(false)
  availableTodayEscort        Boolean   @default(false)
  availableNowWebcam          Boolean   @default(false)
  availableNowPhoneChat       Boolean   @default(false)
  hasGallery                  Boolean   @default(false)
  hasPrivateGallery           Boolean   @default(false)
  hasMovieClips               Boolean   @default(false)
  hasMovieRentals             Boolean   @default(false)
  hasSaleItems                Boolean   @default(false)
  ratingTotal                 Int       @default(0)
  ratingPositive              Int       @default(0)
  ratingNeutral               Int       @default(0)
  ratingNegative              Int       @default(0)
  profileUrl                  String?
  thumbnailUrl                String?   // Excluded in discreet mode
  squareUrl                   String?   // Excluded in discreet mode
  lastUpdated                 DateTime?
  lastSynced                  DateTime  @default(now())
}

model SyncConfig {
  id             Int       @id @default(1)
  interval       String    @default("manual") // "manual", "hourly", "daily", "twicedaily"
  lastSyncedAt   DateTime?
  syncInProgress Boolean   @default(false)
  updatedAt      DateTime  @updatedAt
}

model SyncLog {
  id             Int       @id @default(autoincrement())
  startedAt      DateTime  @default(now())
  completedAt    DateTime?
  status         String    // "RUNNING", "SUCCESS", "FAILED"
  profilesSynced Int       @default(0)
  errorMessage   String?
}
